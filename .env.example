# Answer synthesis via OpenRouter (or any OpenAI-compatible endpoint).
# Copy to .env and fill in. Leave unset to disable /search include_answer.
OPENROUTER_API_KEY=
# Any model slug your endpoint accepts (OpenRouter format shown).
ANSWER_MODEL=openai/gpt-4o-mini
# Override to point at a different OpenAI-compatible endpoint (Ollama, vLLM, etc.).
ANSWER_BASE_URL=https://openrouter.ai/api/v1
